{% extends 'base.html.twig' %}

{% block title %}{{ error_title }} - HubIncub{% endblock %}

{% block body %}
{# Mise en page d'erreur partagée par les gabarits d'exception Symfony et les routes locales de prévisualisation. #}
<main class="error-page">
    <section class="error-hero">
        <div class="error-content">
            <a class="brand error-brand" href="{{ path('app_home') }}" aria-label="Accueil HubIncub">
                <span>HubIncub</span>
            </a>
            <p class="eyebrow">{{ error_code }}</p>
            <h1>{{ error_title }}</h1>
            <p class="hero-text">{{ error_message }}</p>
            <div class="hero-actions">
                <a class="button primary" href="{{ path('app_home') }}">Retour à l'accueil</a>
                <a class="button secondary" href="{{ path('app_anciens') }}">Voir les portfolios</a>
            </div>
        </div>
    </section>
</main>
{% endblock %}
