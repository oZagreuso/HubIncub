{% extends 'base.html.twig' %}

{% block title %}Membres - Administration HubIncub{% endblock %}

{% block body %}
<header class="site-header" data-header>
    <a class="brand" href="{{ path('app_home') }}" aria-label="Accueil HubIncub">
        <img src="/images/branding/logo-hubincub.png" alt="HubIncub" width="1448" height="1086" decoding="async">
        <span>HubIncub</span>
    </a>

    <button class="menu-toggle" type="button" aria-controls="main-menu" aria-expanded="false" data-menu-toggle>
        <span class="menu-toggle-label">Ouvrir le menu</span>
        <span aria-hidden="true"></span>
    </button>

    <nav id="main-menu" class="main-nav" aria-label="Navigation principale" data-main-nav>
        <a href="{{ path('app_admin') }}">Admin</a>
        <a href="{{ path('app_home') }}#reseau">Réseau</a>
        <a href="{{ path('app_projets') }}">Projets</a>
        <a href="{{ path('app_evenements') }}">Événements</a>
        <a href="{{ path('app_actualites') }}">Actualités</a>
        <a href="{{ path('app_anciens') }}">Portfolios</a>
        <a class="nav-action" href="{{ path('app_logout') }}">Déconnexion</a>
    </nav>
</header>

<main>
    <section class="admin-shell">
        <div class="admin-heading admin-card">
            <div>
                <p class="eyebrow">Administration</p>
                <h1>Membres HubIncub</h1>
                <p class="hero-text">Vue compacte des fiches, accès, promotions et rôles du réseau.</p>
            </div>
            <div class="admin-heading-aside">
                <img class="admin-heading-logo" src="/images/branding/logo-hubincub.png" alt="HubIncub" width="1448" height="1086" decoding="async">
                <span class="admin-role-pill">{{ is_granted('ROLE_ADMIN') ? 'Administrateur' : 'Délégué' }}</span>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <p class="form-success">{{ message }}</p>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <p class="form-alert">{{ message }}</p>
        {% endfor %}

        <div class="admin-stats">
            <article class="admin-stat"><span>Total</span><strong>{{ memberStats.total }}</strong></article>
            <article class="admin-stat"><span>Incubateurs</span><strong>{{ memberStats.incubators }}</strong></article>
            <article class="admin-stat"><span>Anciens</span><strong>{{ memberStats.alumni }}</strong></article>
            <article class="admin-stat"><span>Avec accès</span><strong>{{ memberStats.withAccount }}</strong></article>
            <article class="admin-stat"><span>Sans accès</span><strong>{{ memberStats.withoutAccount }}</strong></article>
        </div>

        <details class="admin-card admin-card-wide admin-create-panel">
            <summary class="admin-panel-summary">
                <span>Ajouter un membre</span>
                <span class="button primary">Ouvrir</span>
            </summary>
            <form class="admin-form admin-member-create-form" method="post">
                <input type="hidden" name="type" value="portfolio">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_portfolio') }}">

                <label>Prénom obligatoire <input name="firstName" required></label>
                <label>Nom obligatoire <input name="lastName" required></label>
                <label>Promotion obligatoire <input name="promotion" inputmode="numeric" pattern="[0-9]{4}" maxlength="4" placeholder="2026" required></label>
                <label>
                    Statut obligatoire
                    <select name="role" required>
                        <option value="Incubateur">Incubateur</option>
                        <option value="Ancien étudiant">Ancien étudiant</option>
                    </select>
                </label>
                <label>Email obligatoire <input type="email" name="email" required></label>
                <label>Portfolio obligatoire <input type="url" name="url" required></label>
                <label>Profil LinkedIn optionnel <input type="url" name="linkedinUrl" placeholder="https://www.linkedin.com/in/..."></label>
                <label>Code postal optionnel <input name="postalCode" inputmode="text" maxlength="12" placeholder="57000 ou L-1234"></label>
                <div class="password-field" data-password-tools>
                    <label>
                        Mot de passe obligatoire
                        <input type="password" name="password" data-password-input required minlength="12" autocomplete="new-password">
                    </label>
                    <p class="field-help">Règle CNIL : 12 caractères minimum avec majuscule, minuscule, chiffre et caractère spécial.</p>
                    <div class="password-actions">
                        <button class="button secondary" type="button" data-password-generate>Générer</button>
                        <button class="button secondary" type="button" data-password-toggle>Voir</button>
                    </div>
                </div>
                <label>Confirmer le mot de passe obligatoire <input type="password" name="passwordConfirmation" data-password-confirm required minlength="12" autocomplete="new-password"></label>
                <button class="button primary" type="submit">Ajouter</button>
            </form>
        </details>

        {% if is_granted('ROLE_ADMIN') %}
            <details class="admin-card admin-card-wide admin-create-panel">
                <summary class="admin-panel-summary">
                    <span>Délégué des Incubateurs</span>
                    <span class="button secondary">Gérer</span>
                </summary>
                <form class="admin-form admin-form-inline" method="post">
                    <input type="hidden" name="type" value="set_delegate">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_set_delegate') }}">

                    <label>
                        Membre délégué unique
                        <select name="portfolioId" required>
                            {% for portfolio in allPortfolios %}
                                {% set memberUser = usersByEmail[portfolio.email|lower] ?? null %}
                                {% if memberUser and 'ROLE_ADMIN' not in memberUser.roles %}
                                    <option value="{{ portfolio.id }}" {{ delegatePortfolioId == portfolio.id ? 'selected' : '' }}>
                                        {{ portfolio.firstName }} {{ portfolio.lastName }} - {{ portfolio.role }}
                                    </option>
                                {% endif %}
                            {% endfor %}
                        </select>
                    </label>
                    <button class="button primary" type="submit">Définir</button>
                </form>
            </details>
        {% endif %}

        <article class="admin-card admin-card-wide">
            <div class="admin-section-heading">
                <div>
                    <h2>Liste des membres</h2>
                    <p>{{ portfolios|length }} résultat{{ portfolios|length > 1 ? 's' : '' }} affiché{{ portfolios|length > 1 ? 's' : '' }}</p>
                </div>
                <a class="button secondary" href="{{ path('app_admin_members') }}">Réinitialiser</a>
            </div>

            <nav class="admin-quick-filters" aria-label="Filtres rapides">
                <a class="{{ filters.status == '' and filters.account == '' and filters.profile == '' ? 'is-active' : '' }}" href="{{ path('app_admin_members') }}">Tous</a>
                <a class="{{ filters.status == 'Incubateur' ? 'is-active' : '' }}" href="{{ path('app_admin_members', {status: 'Incubateur'}) }}">Incubateurs</a>
                <a class="{{ filters.status == 'Ancien étudiant' ? 'is-active' : '' }}" href="{{ path('app_admin_members', {status: 'Ancien étudiant'}) }}">Anciens</a>
                <a class="{{ filters.profile == 'without_photo' ? 'is-active' : '' }}" href="{{ path('app_admin_members', {profile: 'without_photo'}) }}">Sans photo</a>
                <a class="{{ filters.profile == 'without_linkedin' ? 'is-active' : '' }}" href="{{ path('app_admin_members', {profile: 'without_linkedin'}) }}">Sans LinkedIn</a>
                <a class="{{ filters.account == 'without_account' ? 'is-active' : '' }}" href="{{ path('app_admin_members', {account: 'without_account'}) }}">Sans accès</a>
                <a class="{{ filters.account == 'delegate' ? 'is-active' : '' }}" href="{{ path('app_admin_members', {account: 'delegate'}) }}">Délégué</a>
            </nav>

            <form class="admin-form admin-filters" method="get">
                <label>Recherche <input name="q" value="{{ filters.q }}" placeholder="Nom, prénom, email..."></label>
                <label>
                    Statut
                    <select name="status">
                        <option value="">Tous</option>
                        <option value="Incubateur" {{ filters.status == 'Incubateur' ? 'selected' : '' }}>Incubateurs</option>
                        <option value="Ancien étudiant" {{ filters.status == 'Ancien étudiant' ? 'selected' : '' }}>Anciens étudiants</option>
                    </select>
                </label>
                <label>
                    Promotion
                    <select name="promotion">
                        <option value="">Toutes</option>
                        {% for promotion in promotions %}
                            <option value="{{ promotion }}" {{ filters.promotion == promotion ? 'selected' : '' }}>{{ promotion }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label>
                    Accès
                    <select name="account">
                        <option value="">Tous</option>
                        <option value="with_account" {{ filters.account == 'with_account' ? 'selected' : '' }}>Avec compte</option>
                        <option value="without_account" {{ filters.account == 'without_account' ? 'selected' : '' }}>Sans compte</option>
                        <option value="admin" {{ filters.account == 'admin' ? 'selected' : '' }}>Administrateurs</option>
                        <option value="delegate" {{ filters.account == 'delegate' ? 'selected' : '' }}>Délégué</option>
                    </select>
                </label>
                <input type="hidden" name="profile" value="{{ filters.profile }}">
                <button class="button primary" type="submit">Filtrer</button>
            </form>

            <ul class="admin-list admin-member-list admin-member-list-compact">
                {% for portfolio in portfolios %}
                    {% set memberUser = usersByEmail[portfolio.email|lower] ?? null %}
                    {% set userRoles = memberUser ? memberUser.roles : [] %}
                    {% set canEditPortfolio = is_granted('ROLE_ADMIN') or portfolio.id not in adminPortfolioIds %}
                    <li>
                        <div class="admin-member-row admin-member-row-compact">
                            <div class="admin-member-identity">
                                {% if portfolio.photoFilename %}
                                    <img class="admin-member-photo" src="/uploads/portfolios/{{ portfolio.photoFilename }}" alt="Photo de {{ portfolio.firstName }} {{ portfolio.lastName }}" width="96" height="96" loading="lazy" decoding="async">
                                {% else %}
                                    <span class="admin-member-avatar">{{ (portfolio.firstName|first ~ portfolio.lastName|first)|upper }}</span>
                                {% endif %}
                                <div class="admin-member-main">
                                    <strong>{{ portfolio.firstName }} {{ portfolio.lastName }}</strong>
                                    <span>{{ portfolio.email }}</span>
                                    <div class="admin-member-tags">
                                        <span>{{ portfolio.role }}</span>
                                        <span>{{ portfolio.promotion ? 'Promotion ' ~ portfolio.promotion : 'Promotion à définir' }}</span>
                                        {% if 'ROLE_ADMIN' in userRoles %}
                                            <span>Administrateur</span>
                                        {% elseif 'ROLE_DELEGATE' in userRoles %}
                                            <span>Délégué</span>
                                        {% elseif memberUser %}
                                            <span>Compte actif</span>
                                        {% else %}
                                            <span>Sans accès</span>
                                        {% endif %}
                                        {% if not portfolio.photoFilename %}
                                            <span>Sans photo</span>
                                        {% endif %}
                                        {% if not portfolio.linkedinUrl %}
                                            <span>Sans LinkedIn</span>
                                        {% endif %}
                                        {% if portfolio.postalCode %}
                                            <span>{{ portfolio.postalCode }}</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            <div class="admin-row-actions">
                                {% if canEditPortfolio %}
                                    <a class="button primary" href="{{ path('app_admin_member_edit', {id: portfolio.id}) }}">Modifier</a>
                                {% endif %}

                                <details class="admin-actions-menu">
                                    <summary class="button secondary">Actions</summary>
                                    <div class="admin-actions-menu-panel">
                                        {% if is_granted('ROLE_ADMIN') and portfolio.role == 'Incubateur' %}
                                            <form method="post">
                                                <input type="hidden" name="type" value="graduate_portfolio">
                                                <input type="hidden" name="portfolioId" value="{{ portfolio.id }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_graduate_portfolio') }}">
                                                <button class="button secondary" type="submit">Passer ancien</button>
                                            </form>
                                        {% endif %}
                                        {% if portfolio.photoFilename %}
                                            <form method="post" onsubmit="return confirm('Supprimer la photo de ce membre ?');">
                                                <input type="hidden" name="type" value="delete_portfolio_photo">
                                                <input type="hidden" name="portfolioId" value="{{ portfolio.id }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_delete_portfolio_photo') }}">
                                                <button class="button danger" type="submit">Supprimer photo</button>
                                            </form>
                                        {% endif %}
                                        {% if is_granted('ROLE_ADMIN') %}
                                            <form method="post" onsubmit="return confirm('Supprimer ce membre ?');">
                                                <input type="hidden" name="type" value="delete_portfolio">
                                                <input type="hidden" name="portfolioId" value="{{ portfolio.id }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_delete_portfolio') }}">
                                                <button class="button danger" type="submit">Supprimer membre</button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </details>
                            </div>
                        </div>
                    </li>
                {% else %}
                    <li>Aucun membre ne correspond aux filtres.</li>
                {% endfor %}
            </ul>
        </article>
    </section>
</main>
{% endblock %}
