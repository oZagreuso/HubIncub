{% extends 'base.html.twig' %}

{% block title %}Mentions légales - HubIncub{% endblock %}

{% block body %}
<header class="site-header" data-header>
    <a class="brand" href="{{ path('app_home') }}" aria-label="Accueil HubIncub">
        <img src="/images/branding/logo-hubincub.png" alt="HubIncub" width="1448" height="1086" decoding="async">
        <span>HubIncub</span>
    </a>

    <nav class="main-nav" aria-label="Navigation principale">
        <a href="{{ path('app_home') }}#reseau">Réseau</a>
        <a href="{{ path('app_projets') }}">Projets</a>
        <a href="{{ path('app_evenements') }}">Événements</a>
        <a href="{{ path('app_actualites') }}">Actualités</a>
        <a class="nav-action" href="{{ path('app_admin') }}">Administration</a>
    </nav>
</header>

<main>
    <section class="directory-hero legal-hero">
        <p class="eyebrow">Informations légales</p>
        <h1>Mentions légales.</h1>
        <p class="hero-text">
            Cette page rassemble les informations relatives à l'édition, l'hébergement
            et l'utilisation du site HubIncub.
        </p>
    </section>

    <section class="section legal-section">
        <div class="legal-grid">
            <article class="legal-card">
                <span>01</span>
                <h2>Éditeur du site</h2>
                <p>
                    Le site HubIncub est édité dans le cadre du réseau des anciens incubateurs
                    de Metz Numeric School.
                </p>
                <p>
                    Pour toute demande liée au site, à une information publiée ou à votre fiche
                    membre, vous pouvez contacter l'administration via l'espace prévu à cet effet.
                </p>
            </article>

            <article class="legal-card">
                <span>02</span>
                <h2>Hébergement</h2>
                <p>
                    Les informations d'hébergement technique du site sont tenues à jour par
                    l'administrateur HubIncub et peuvent être communiquées sur demande.
                </p>
            </article>

            <article class="legal-card">
                <span>03</span>
                <h2>Données personnelles</h2>
                <p>
                    Les données affichées sur HubIncub servent à présenter le réseau, les projets,
                    les événements, les actualités et les portfolios des membres.
                </p>
                <p>
                    Vous pouvez demander la modification ou la suppression des informations vous
                    concernant auprès de l'administration du site.
                </p>
            </article>

            <article class="legal-card">
                <span>04</span>
                <h2>Propriété intellectuelle</h2>
                <p>
                    Les contenus, textes, visuels, logos et éléments graphiques présents sur le
                    site restent la propriété de leurs titulaires respectifs.
                </p>
                <p>
                    Toute réutilisation doit respecter les droits applicables et obtenir les
                    autorisations nécessaires lorsque le contenu n'est pas librement réutilisable.
                </p>
            </article>

            <article class="legal-card legal-card-wide">
                <span>05</span>
                <h2>Responsabilité</h2>
                <p>
                    HubIncub met à disposition des informations destinées à valoriser la communauté
                    alumni. Malgré le soin apporté à leur mise à jour, des erreurs ou omissions
                    peuvent subsister.
                </p>
                <p>
                    Les liens externes publiés sur le site relèvent de la responsabilité de leurs
                    éditeurs respectifs.
                </p>
            </article>
        </div>
    </section>

    {% include 'partials/_footer.html.twig' with {
        footer_class: 'legal-footer',
        footer_title: 'Retour au réseau des anciens.',
        footer_text: 'Retrouvez les projets, les actualités et les événements de la communauté.',
        footer_primary_label: 'Accueil',
        footer_primary_href: path('app_home')
    } %}
</main>
{% endblock %}
