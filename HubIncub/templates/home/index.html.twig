{% extends 'base.html.twig' %}

{% block title %}HubIncub - Alumni de l'incubateur Metz Numeric School{% endblock %}

{% block body %}
<header class="site-header" data-header>
    <a class="brand" href="/" aria-label="Accueil HubIncub">
        <img src="/images/logo-hubincub.png" alt="HubIncub">
        <span>HubIncub</span>
    </a>

    <nav class="main-nav" aria-label="Navigation principale">
        <a href="#reseau">Reseau</a>
        <a href="#projets">Projets</a>
        <a href="#evenements">Evenements</a>
        <a class="nav-action" href="#rejoindre">Rejoindre</a>
    </nav>
</header>

<main>
    <section class="hero">
        <div class="hero-content">
            <img class="hero-logo" src="/images/logo-hubincub.png" alt="HubIncub">
            <p class="eyebrow">Incubateur Metz Numeric School</p>

            <h1>Le hub des anciens eleves qui continuent a construire.</h1>

            <p class="hero-text">
                Retrouvez les alumni, partagez vos projets, creez des opportunites
                et gardez le lien avec l'ecosysteme entrepreneurial de Metz.
            </p>

            <div class="hero-actions">
                <a class="button primary" href="#rejoindre">Rejoindre le hub</a>
                <a class="button secondary" href="#reseau">Decouvrir le reseau</a>
            </div>
        </div>

        <aside class="hero-panel" aria-label="Apercu du hub">
            <div>
                <span class="metric">Alumni</span>
                <strong>Un reseau vivant</strong>
            </div>
            <div>
                <span class="metric">Projets</span>
                <strong>Des idees qui avancent</strong>
            </div>
            <div>
                <span class="metric">Metz</span>
                <strong>Une communaute locale</strong>
            </div>
        </aside>
    </section>

    <section id="reseau" class="section">
        <div class="section-heading">
            <p class="eyebrow">Reseau alumni</p>
            <h2>Un espace pour continuer l'aventure apres l'incubateur.</h2>
        </div>

        <div class="features">
            <article class="feature-link-card">
                <span>01</span>
                <h3>Retrouver les anciens</h3>
                <p>Gardez le contact avec les promotions precedentes, suivez les parcours et ouvrez de nouvelles discussions.</p>
                <a class="card-link" href="{{ path('app_anciens') }}" aria-label="Voir les portfolios des anciens etudiants"></a>
            </article>

            <article>
                <span>02</span>
                <h3>Partager les projets</h3>
                <p>Mettez en avant vos startups, prototypes, missions freelances ou initiatives nees autour de Metz.</p>
            </article>

            <article>
                <span>03</span>
                <h3>Creer des opportunites</h3>
                <p>Publiez des offres, des evenements, des appels a projets et des collaborations entre alumni.</p>
            </article>
        </div>
    </section>

    <section id="projets" class="split-section">
        <div>
            <p class="eyebrow">Projets</p>
            <h2>Une vitrine pour celles et ceux qui lancent, testent et apprennent.</h2>
        </div>
        <p>
            HubIncub peut devenir le point d'entree pour decouvrir les projets issus de l'incubateur,
            identifier les competences de chacun et donner de la visibilite aux initiatives des anciens.
        </p>
    </section>

    <section id="evenements" class="section section-soft">
        <div class="section-heading">
            <p class="eyebrow">Evenements</p>
            <h2>Des rencontres pour garder le lien.</h2>
        </div>

        <div class="event-list">
            <article>
                <time>Afterworks</time>
                <p>Des rendez-vous simples pour echanger sur les projets, les besoins et les retours d'experience.</p>
            </article>
            <article>
                <time>Demo days</time>
                <p>Des moments pour presenter une avancee, demander un avis ou trouver un futur partenaire.</p>
            </article>
        </div>
    </section>

    <section id="rejoindre" class="join-section">
        <div>
            <p class="eyebrow">Rejoindre</p>
            <h2>Bienvenue dans le hub des anciens.</h2>
            <p>La prochaine etape sera d'ajouter l'espace membre, les profils alumni et les projets.</p>
        </div>
        <a class="button primary" href="mailto:contact@metznumericschool.fr">Demander un acces</a>
    </section>
</main>
{% endblock %}
