{% extends 'base.html.twig' %}

{% block title %}HubIncub - Alumni de l'incubateur Metz Numeric School{% endblock %}

{% block body %}
{# Public header with navigation to the main site sections and the protected admin entry. #}
<header class="site-header" data-header>
    <a class="brand" href="/" aria-label="Accueil HubIncub">
        <img src="/images/logo-hubincub.png" alt="HubIncub" width="1448" height="1086" decoding="async">
        <span>HubIncub</span>
    </a>

    <nav class="main-nav" aria-label="Navigation principale">
        <a href="#reseau">Réseau</a>
        <a href="#projets">Projets</a>
        <a href="{{ path('app_admin') }}">Administration</a>
        <a class="nav-action" href="#rejoindre">Rejoindre</a>
    </nav>
</header>

<main>
    {# Front-page hero introducing the HubIncub network. #}
    <section class="hero">
        <div class="hero-content">
            <img class="hero-logo" src="/images/logo-hubincub.png" alt="Logo HubIncub" width="1448" height="1086" fetchpriority="high" decoding="async">
            <p class="eyebrow">Incubateur Metz Numeric School</p>

            <h1>Le hub des anciens incubateurs de MNS</h1>

            <p class="hero-text">
                Retrouvez les alumni, partagez vos projets, créez des opportunités
                et conservez des liens.
            </p>

            <div class="hero-actions">
                <a class="button primary" href="#rejoindre">Rejoindre le hub</a>
                <a class="button secondary" href="#reseau">Découvrir le réseau</a>
            </div>
        </div>

        <aside class="hero-panel" aria-label="Aperçu du hub">
            <img class="school-logo" src="/images/logo-mns.webp" alt="Logo Metz Numeric School" width="816" height="768" loading="lazy" decoding="async">
            <div>
                <span class="metric">Alumni</span>
                <strong>Un réseau vivant</strong>
            </div>
            <div>
                <span class="metric">Projets</span>
                <strong>Des idées qui avancent</strong>
            </div>
            <div>
                <span class="metric">Metz</span>
                <strong>Une communauté locale</strong>
            </div>
        </aside>
    </section>

    {% if latestNews %}
        {# Latest news item managed from the administration interface. #}
        <section class="latest-news-section">
            <article class="latest-news-card">
                <div class="latest-news-content">
                    <p class="eyebrow">Actualité</p>
                    <h2>{{ latestNews.title }}</h2>
                    <p>{{ latestNews.content }}</p>
                    <time datetime="{{ latestNews.publishedAt|date('c') }}">{{ latestNews.publishedAt|date('d/m/Y') }}</time>
                </div>

                {% if latestNews.imageFilename %}
                    <img
                        class="latest-news-image"
                        src="/uploads/admin/{{ latestNews.imageFilename }}"
                        alt="{{ latestNews.imageAlt ?: 'Illustration de l’actualité ' ~ latestNews.title }}"
                        width="960"
                        height="540"
                        loading="lazy"
                        decoding="async"
                    >
                {% endif %}
            </article>
        </section>
    {% endif %}

    {# Network section linking to the public portfolio directory. #}
    <section id="reseau" class="section">
        <div class="section-heading">
            <p class="eyebrow">Réseau alumni</p>
            <h2>Un espace pour continuer l'aventure après l'incubateur.</h2>
        </div>

        <div class="features">
            <article class="feature-link-card">
                <span>01</span>
                <h3>Retrouver les anciens</h3>
                <p>Gardez le contact avec les promotions précédentes, suivez les parcours et ouvrez de nouvelles discussions.</p>
                <a class="card-link" href="{{ path('app_anciens') }}" aria-label="Voir les portfolios des anciens étudiants"></a>
            </article>

            <article>
                <span>02</span>
                <h3>Partager les projets</h3>
                <p>Mettez en avant vos startups, prototypes, missions freelances ou initiatives nées autour de Metz.</p>
            </article>

            <article>
                <span>03</span>
                <h3>Créer des opportunités</h3>
                <p>Publiez des offres, des événements, des appels à projets et des collaborations entre alumni.</p>
            </article>
        </div>
    </section>

    {# Project teaser section, styled with the light geometric background asset. #}
    <section id="projets" class="split-section">
        <div>
            <p class="eyebrow">Projets</p>
            <h2>Une vitrine pour celles et ceux qui lancent, testent et apprennent.</h2>
        </div>
        <p>
            HubIncub peut devenir le point d'entrée pour découvrir les projets issus de l'incubateur,
            identifier les compétences de chacun et donner de la visibilité aux initiatives des anciens.
        </p>
    </section>

    {# Contact call-to-action shown at the end of the front page. #}
    <section id="rejoindre" class="join-section">
        <div>
            <p class="eyebrow">Rejoindre</p>
            <h2>Bienvenue dans le hub des anciens.</h2>
            <p>La prochaine étape sera d'ajouter l'espace membre, les profils alumni et les projets.</p>
        </div>
        <a class="button primary" href="mailto:contact@metznumericschool.fr">Demander un accès</a>
    </section>
</main>
{% endblock %}
