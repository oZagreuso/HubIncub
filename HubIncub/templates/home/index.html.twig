{% extends 'base.html.twig' %}

{% block title %}HubIncub - Alumni de l'incubateur Metz Numeric School{% endblock %}

{% block body %}
{# En-tête public avec navigation vers les sections principales et l'entrée d'administration protégée. #}
<header class="site-header" data-header>
    <a class="brand" href="/" aria-label="Accueil HubIncub">
        <img src="/images/branding/logo-hubincub.png" alt="HubIncub" width="1448" height="1086" decoding="async">
        <span>HubIncub</span>
    </a>

    <nav class="main-nav" aria-label="Navigation principale">
        <a href="#reseau">Réseau</a>
        <a href="{{ path('app_projets') }}">Projets</a>
        <a href="{{ path('app_evenements') }}">Événements</a>
        <a href="{{ path('app_actualites') }}">Actualités</a>
        <a class="nav-action" href="{{ path('app_admin') }}">Administration</a>
    </nav>
</header>

<main>
    {# Héros de page d'accueil présentant le réseau HubIncub. #}
    <section class="hero">
        <div class="hero-content">
            <img class="hero-logo" src="/images/branding/logo-hubincub.png" alt="Logo HubIncub" width="1448" height="1086" fetchpriority="high" decoding="async">
            <p class="eyebrow">Incubateur Metz Numeric School</p>

            <h1>Le hub des anciens incubateurs de MNS</h1>

            <p class="hero-text">
                Retrouvez les alumni, partagez vos projets, créez des opportunités
                et conservez des liens.
            </p>

            <div class="hero-actions">
                <a class="button primary" href="{{ path('app_admin') }}">Administration</a>
                <a class="button secondary" href="#reseau">Découvrir le réseau</a>
            </div>
        </div>

        <aside class="hero-panel" aria-label="Aperçu du hub">
            <div class="partner-logos" aria-label="Écoles partenaires">
                <img class="school-logo" src="/images/partners/logo-mns.webp" alt="Logo Metz Numeric School" width="816" height="768" loading="lazy" decoding="async">
                <img class="school-logo ifa-logo" src="/images/partners/ifalogo.jpg" alt="Logo IFA Business School" width="225" height="225" loading="lazy" decoding="async">
            </div>
            <div>
                <span class="metric">Alumni</span>
                <strong>Un réseau vivant</strong>
            </div>
            <div>
                <span class="metric">Projets</span>
                <strong>Des idées qui avancent</strong>
            </div>
            <div>
                <span class="metric">Metz</span>
                <strong>Une communauté locale</strong>
            </div>
        </aside>
    </section>

    {% if latestNews or latestProject or latestEvent %}
        {# Flux éditorial regroupant les derniers contenus administrés sous un même rythme visuel. #}
        <section class="front-feed-section">
            <div class="front-feed-heading">
                <p class="eyebrow">À la une</p>
                <h2>Les dernières nouvelles du réseau.</h2>
            </div>

            {% if latestNews %}
                <article class="latest-news-card">
                    <div class="latest-news-content">
                        <p class="eyebrow">Actualité</p>
                        <h2>{{ latestNews.title }}</h2>
                        <p>{{ latestNews.content }}</p>
                        <time datetime="{{ latestNews.publishedAt|date('c') }}">{{ latestNews.publishedAt|date('d/m/Y') }}</time>
                    </div>

                    {% if latestNews.imageFilename %}
                        <img
                            class="latest-news-image"
                            src="/uploads/admin/news/{{ latestNews.imageFilename }}"
                            alt="{{ latestNews.imageAlt ?: 'Illustration de l’actualité ' ~ latestNews.title }}"
                            width="960"
                            height="540"
                            loading="lazy"
                            decoding="async"
                        >
                    {% endif %}
                </article>
            {% endif %}

            {% if latestProject or latestEvent %}
                <div class="front-highlights-grid">
                    {% if latestProject %}
                        <article class="content-card">
                            {% if latestProject.imageFilename %}
                                <img
                                    src="/uploads/admin/projects/{{ latestProject.imageFilename }}"
                                    alt="{{ latestProject.imageAlt ?: 'Illustration du projet ' ~ latestProject.name }}"
                                    width="960"
                                    height="540"
                                    loading="lazy"
                                    decoding="async"
                                >
                            {% endif %}
                            <div>
                                <p class="eyebrow">Dernier projet</p>
                                <h2>{{ latestProject.name }}</h2>
                                <p>{{ latestProject.description }}</p>
                                <a class="button secondary" href="{{ path('app_projets') }}">Voir les projets</a>
                            </div>
                        </article>
                    {% endif %}

                    {% if latestEvent %}
                        <article class="content-card">
                            {% if latestEvent.imageFilename %}
                                <img
                                    src="/uploads/admin/events/{{ latestEvent.imageFilename }}"
                                    alt="{{ latestEvent.imageAlt ?: 'Illustration de l’événement ' ~ latestEvent.title }}"
                                    width="960"
                                    height="540"
                                    loading="lazy"
                                    decoding="async"
                                >
                            {% endif %}
                            <div>
                                <p class="eyebrow">Dernier événement</p>
                                <h2>{{ latestEvent.title }}</h2>
                                <p>{{ latestEvent.description }}</p>
                                {% if latestEvent.startsAt %}
                                    <time datetime="{{ latestEvent.startsAt|date('c') }}">{{ latestEvent.startsAt|date('d/m/Y H:i') }}</time>
                                {% endif %}
                                <a class="button secondary" href="{{ path('app_evenements') }}">Voir les événements</a>
                            </div>
                        </article>
                    {% endif %}
                </div>
            {% endif %}
        </section>
    {% endif %}

    {# Section réseau menant vers l'annuaire public des portfolios. #}
    <section id="reseau" class="section">
        <div class="section-heading">
            <p class="eyebrow">Réseau alumni</p>
            <h2>Un espace pour continuer l'aventure après l'incubateur.</h2>
        </div>

        <div class="features">
            <article class="feature-link-card">
                <span>01</span>
                <h3>Retrouver les anciens</h3>
                <p>Gardez le contact avec les promotions précédentes, suivez les parcours et ouvrez de nouvelles discussions.</p>
                <a class="card-link" href="{{ path('app_anciens') }}" aria-label="Voir les portfolios des anciens étudiants"></a>
            </article>

            <article class="feature-link-card">
                <span>02</span>
                <h3>Partager les projets</h3>
                <p>Mettez en avant vos startups, prototypes, missions freelances ou initiatives nées autour de Metz.</p>
                <a class="card-link" href="{{ path('app_projets') }}" aria-label="Voir les projets du réseau"></a>
            </article>

            <article class="feature-link-card">
                <span>03</span>
                <h3>Créer des opportunités</h3>
                <p>Publiez des offres, des événements, des appels à projets et des collaborations entre alumni.</p>
                <a class="card-link" href="{{ path('app_evenements') }}" aria-label="Voir les événements du réseau"></a>
            </article>
        </div>
    </section>

    {% include 'partials/_footer.html.twig' %}
</main>
{% endblock %}
