{% extends 'base.html.twig' %}

{% block title %}Actualités - HubIncub{% endblock %}

{% block body %}
<header class="site-header" data-header>
    <a class="brand" href="{{ path('app_home') }}" aria-label="Accueil HubIncub">
        <span>HubIncub</span>
    </a>

    <button class="menu-toggle" type="button" aria-controls="main-menu" aria-expanded="false" data-menu-toggle>
        <span class="menu-toggle-label">Ouvrir le menu</span>
        <span aria-hidden="true"></span>
    </button>

    <nav id="main-menu" class="main-nav" aria-label="Navigation principale" data-main-nav>
        <a href="{{ path('app_home') }}#reseau">Réseau</a>
        <a href="{{ path('app_projets') }}">Projets</a>
        <a href="{{ path('app_evenements') }}">Événements</a>
        <a href="{{ path('app_actualites') }}">Actualités</a>
        <a class="nav-action" href="{{ path('app_admin') }}">Administration</a>
    </nav>
</header>

<main>
    <section class="directory-hero">
        <p class="eyebrow">Actualités</p>
        <h1>Toutes les actualités HubIncub.</h1>
        <p class="hero-text">Retrouvez les informations publiées par l'administration et les temps forts du réseau.</p>
    </section>

    <section class="section">
        <div class="content-grid">
            {% for news in newsItems %}
                <article class="content-card">
                    {% if news.imageFilename %}
                        <img src="/uploads/admin/news/{{ news.imageFilename }}" alt="{{ news.imageAlt ?: 'Illustration de l’actualité ' ~ news.title }}" width="960" height="540" loading="lazy" decoding="async">
                    {% endif %}
                    <div>
                        <p class="eyebrow">Actualité</p>
                        <h2>{{ news.title }}</h2>
                        <time datetime="{{ news.publishedAt|date('c') }}">{{ news.publishedAt|date('d/m/Y H:i') }}</time>
                        <p>{{ news.content }}</p>
                    </div>
                </article>
            {% else %}
                <p class="empty-state">Aucune actualité n'est publiée pour le moment.</p>
            {% endfor %}
        </div>
    </section>

    {% include 'partials/_footer.html.twig' %}
</main>
{% endblock %}
